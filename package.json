{
  "name": "phonebook",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @phonebook/database generate",
    "db:push": "pnpm --filter @phonebook/database push",
    "db:migrate": "pnpm --filter @phonebook/database migrate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0"
  },
  "packageManager": "pnpm@9.0.0"
}
