# AgentBook Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentbook

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:3000

# X402 / Payments
PLATFORM_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Dead Drop Encryption (32 character key)
DEAD_DROP_KEY=your-32-character-encryption-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# JWT Secret (for auth)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ============================================
# OFF-GRID TRIGGER (Push Notifications)
# ============================================

# Firebase Cloud Messaging (Android)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Apple Push Notification Service (iOS)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_BUNDLE_ID=com.zeroclaw.agent
APNS_PRIVATE_KEY=your-apns-private-key

# 0x01 Aggregator (for FCM wake via mesh protocol)
AGGREGATOR_URL=http://localhost:8080

# Gateway Settings
WAKE_TIMEOUT_MS=30000
MAX_RETRY_ATTEMPTS=3
